# ============================================
# CONFIGURACIÓN DE PRODUCCIÓN - HOSTINGER
# ============================================
# Copiá este archivo a .env.local en el servidor
# y reemplazá los valores con los de tu hosting

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=generá-un-string-aleatorio-largo-y-seguro

# URL base de tu sitio (sin slash al final)
DEFAULT_URI=https://tudominio.com

# ============================================
# BASE DE DATOS - MYSQL/MARIADB (HOSTINGER)
# ============================================
# Reemplazá con las credenciales que te da Hostinger
# Las encontrás en hPanel > Bases de datos > MySQL
DATABASE_URL="mysql://USUARIO:CONTRASEÑA@localhost:3306/nombre_db?serverVersion=8.0.32&charset=utf8mb4"

# ============================================
# SESIÓN
# ============================================
# Cambiá esto por algo aleatorio y largo
# (lo podés generar con: php -r "echo bin2hex(random_bytes(32));")

# ============================================
# MAIL (opcional, solo si usás envío de emails)
# ============================================
MAILER_DSN=null://null

# ============================================
# MESSENGER
# ============================================
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# ============================================
# APP SHARE DIR
# ============================================
APP_SHARE_DIR=var/share

# ============================================
# APPEND THIS (incluí esto en .env.local)
# ============================================
# TRUSTED_PROXIES=REMOTE_ADDR
# TRUSTED_HOSTS=^(.+\.)?tudominio\.com$

# ============================================
# CONTRASEÑA PANEL ACADEMIA
# ============================================
# Cámbiala por una segura (largo > 12 chars, mayúsculas, números, símbolos)
ACADEMIA_ADMIN_PASS=TU_PASSWORD_SEGURA_AQUI

# ============================================
# CORS (para app mobile en LAN o producción)
# ============================================
# Acepta el dominio de producción, localhost, IP de emulador y LAN
CORS_ALLOW_ORIGIN=^https?://(tudominio\.com|localhost|127\.0\.0\.1|10\.0\.2\.2|192\.168\.\d+\.\d+)(:[0-9]+)?$
