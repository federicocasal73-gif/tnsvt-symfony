<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/tnsvt_gold</item>
        <item name="colorPrimaryDark">@color/tnsvt_dark</item>
        <item name="colorAccent">@color/tnsvt_violet</item>
        <item name="android:windowBackground">@color/tnsvt_dark</item>
        <item name="android:statusBarColor">@color/tnsvt_dark</item>
        <item name="android:navigationBarColor">@color/tnsvt_dark</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@color/tnsvt_dark</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@color/tnsvt_dark</item>
        <item name="android:windowSplashScreenBackground">@color/tnsvt_dark</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
