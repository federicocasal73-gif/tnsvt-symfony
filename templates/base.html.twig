<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
<title>{% block title %}T.N.S.V.T - Reino del Cristo Íntegro{% endblock %}</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⛧</text></svg>">
  {% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
  {% endblock %}
  <script src="{{ asset('api.js') }}"></script>
  {% block javascripts %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
  {% endblock %}
  <style>
  /* ===== MÓDULO MULTIFRACTAL ===== */
  .mf-header { text-align:center; padding:24px 0 18px; border-bottom:1px solid rgba(212,175,55,0.15); margin-bottom:20px; }
  .mf-eyebrow { font-family:'Orbitron',sans-serif; font-size:0.62rem; letter-spacing:3px; color:var(--violet); text-transform:uppercase; margin-bottom:8px; }
  .mf-title { font-family:'Cinzel',serif; font-size:1.7rem; color:var(--gold-bright); margin:0 0 8px; }
  .mf-subtitle { font-size:0.85rem; color:#a499b8; font-style:italic; }

  .mf-tabs-nav { display:flex; gap:4px; flex-wrap:wrap; background:rgba(9,5,18,0.7); border:1px solid rgba(138,60,255,0.2); border-radius:10px; padding:6px; margin-bottom:20px; }
  .mf-tab-btn { flex:1; min-width:80px; padding:9px 6px; background:transparent; border:none; border-radius:7px; color:#645a78; font-family:'Orbitron',sans-serif; font-size:0.6rem; font-weight:700; letter-spacing:1px; cursor:pointer; transition:all 0.25s; white-space:nowrap; }
  .mf-tab-btn:hover { background:rgba(138,60,255,0.1); color:#c4a0ff; }
  .mf-tab-btn.active { background:rgba(138,60,255,0.2); color:var(--gold-bright); border:1px solid rgba(212,175,55,0.3); }

  .mf-panel { display:none; }
  .mf-panel.active { display:block; }

  .mf-section-title { font-family:'Cinzel',serif; font-size:1.05rem; color:var(--gold-bright); margin:20px 0 12px; padding-bottom:6px; border-bottom:1px solid rgba(212,175,55,0.15); }
  .mf-text { font-size:0.84rem; color:#a499b8; line-height:1.75; margin-bottom:14px; }

  .mf-grid2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin:16px 0; }
  @media(max-width:600px){ .mf-grid2 { grid-template-columns:1fr; } }

  .mf-info-card { background:rgba(13,8,24,0.8); border:1px solid rgba(138,60,255,0.2); border-radius:10px; padding:16px; }
  .mf-info-icon { font-size:1.5rem; margin-bottom:8px; }
  .mf-info-title { font-family:'Cinzel',serif; font-size:0.9rem; color:var(--gold-bright); margin-bottom:6px; }
  .mf-info-card p { font-size:0.78rem; color:#a499b8; line-height:1.6; margin:0; }

  .mf-check-card { background:rgba(13,8,24,0.8); border:1px solid rgba(138,60,255,0.25); border-radius:10px; padding:16px; }
  .mf-check-card.valid { border-color:rgba(52,199,89,0.35); }
  .mf-check-card.invalid { border-color:rgba(255,59,48,0.35); }
  .mf-check-label { font-family:'Orbitron',sans-serif; font-size:0.65rem; letter-spacing:1px; font-weight:700; margin-bottom:10px; color:var(--gold-bright); }
  .mf-check-card.valid .mf-check-label { color:#34c759; }
  .mf-check-card.invalid .mf-check-label { color:#ff3b30; }
  .mf-list { padding-left:16px; margin:0; }
  .mf-list li { font-size:0.78rem; color:#a499b8; line-height:1.7; margin-bottom:3px; }

  .mf-gold-box { background:rgba(212,175,55,0.06); border:1px solid rgba(212,175,55,0.25); border-radius:10px; padding:16px 20px; margin:16px 0; }
  .mf-gold-label { font-family:'Orbitron',sans-serif; font-size:0.6rem; letter-spacing:2px; color:var(--gold); text-transform:uppercase; margin-bottom:8px; }
  .mf-gold-box p { font-size:0.84rem; color:#e2dcf0; line-height:1.7; margin:0; font-style:italic; }

  .mf-svg-wrap { background:rgba(9,5,18,0.6); border:1px solid rgba(138,60,255,0.15); border-radius:12px; padding:16px; margin:16px 0; overflow:hidden; }

  .mf-steps-list { display:flex; flex-direction:column; gap:8px; margin:16px 0; }
  .mf-step { display:flex; gap:12px; align-items:flex-start; background:rgba(13,8,24,0.7); border:1px solid rgba(138,60,255,0.15); border-radius:8px; padding:12px 14px; font-size:0.82rem; color:#a499b8; line-height:1.5; }
  .mf-step-num { min-width:26px; height:26px; border-radius:50%; background:rgba(138,60,255,0.2); border:1px solid rgba(138,60,255,0.5); display:flex; align-items:center; justify-content:center; font-family:'Cinzel',serif; font-size:0.8rem; color:#c4a0ff; flex-shrink:0; }

  .mf-info-box-list { display:flex; flex-direction:column; gap:0; border:1px solid rgba(212,175,55,0.15); border-radius:10px; overflow:hidden; margin:12px 0; }
  .mf-info-row { display:grid; grid-template-columns:160px 1fr; gap:10px; padding:12px 16px; border-bottom:1px solid rgba(255,255,255,0.04); font-size:0.8rem; }
  .mf-info-row:last-child { border-bottom:none; }
  .mf-row-label { font-family:'Orbitron',sans-serif; font-size:0.6rem; letter-spacing:1px; color:var(--gold); font-weight:700; align-self:center; }
  .mf-row-val { color:#a499b8; line-height:1.5; }

  .mf-warning-list { display:flex; flex-direction:column; gap:8px; margin:12px 0; }
  .mf-warning { background:rgba(255,59,48,0.06); border:1px solid rgba(255,59,48,0.2); border-radius:8px; padding:10px 14px; font-size:0.8rem; color:#ffaa99; }

  .mf-tf-card { background:rgba(13,8,24,0.8); border:1px solid rgba(138,60,255,0.25); border-radius:10px; padding:16px; margin-bottom:12px; }
  .mf-tf-header { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px; margin-bottom:12px; }
  .mf-tf-style { font-family:'Cinzel',serif; font-size:1rem; }
  .mf-tf-tags { display:flex; gap:6px; flex-wrap:wrap; }
  .mf-tag { font-size:0.65rem; padding:3px 9px; border-radius:20px; font-family:'Orbitron',sans-serif; letter-spacing:1px; }
  .mf-tag.green { background:rgba(52,199,89,0.12); color:#34c759; border:1px solid rgba(52,199,89,0.3); }
  .mf-tag.violet { background:rgba(138,60,255,0.12); color:#c4a0ff; border:1px solid rgba(138,60,255,0.3); }
  .mf-tf-grid { display:grid; grid-template-columns:1fr 1fr; gap:6px; }
  @media(max-width:500px){ .mf-tf-grid { grid-template-columns:1fr; } }
  .mf-tf-grid div { font-size:0.78rem; color:#a499b8; line-height:1.6; }
  .mf-tf-label { color:var(--gold); font-weight:700; margin-right:4px; }

  /* ===== CHECKLIST INTERACTIVO ===== */
  .mf-checklist-wrap { display:flex; flex-direction:column; gap:10px; margin:16px 0; }
  .mf-check-item { display:flex; gap:14px; align-items:flex-start; background:rgba(13,8,24,0.8); border:1px solid rgba(138,60,255,0.2); border-radius:10px; padding:14px 16px; cursor:pointer; transition:all 0.3s; user-select:none; }
  .mf-check-item:hover { background:rgba(138,60,255,0.06); border-color:rgba(138,60,255,0.4); }
  .mf-check-item.checked { background:rgba(52,199,89,0.06); border-color:rgba(52,199,89,0.4); }
  .mf-check-box { width:28px; height:28px; border-radius:6px; border:2px solid rgba(138,60,255,0.4); background:transparent; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:all 0.3s; }
  .mf-check-item.checked .mf-check-box { background:rgba(52,199,89,0.25); border-color:#34c759; }
  .mf-check-tick { font-size:0.9rem; color:#34c759; opacity:0; transform:scale(0.5); transition:all 0.25s; }
  .mf-check-item.checked .mf-check-tick { opacity:1; transform:scale(1); }
  .mf-check-q { font-size:0.84rem; color:#e2dcf0; margin-bottom:4px; font-weight:600; }
  .mf-check-hint { font-size:0.74rem; color:#645a78; line-height:1.5; }

  .mf-result-box { background:rgba(9,5,18,0.9); border:1px solid rgba(138,60,255,0.3); border-radius:12px; padding:20px; text-align:center; margin:20px 0 12px; transition:all 0.4s; }
  .mf-result-box.valid-setup { background:rgba(52,199,89,0.06); border-color:rgba(52,199,89,0.5); }
  .mf-result-box.invalid-setup { background:rgba(255,59,48,0.06); border-color:rgba(255,59,48,0.4); }
  .mf-result-icon { font-size:2rem; margin-bottom:10px; }
  .mf-result-text { font-family:'Cinzel',serif; font-size:1.1rem; color:var(--gold-bright); margin-bottom:6px; }
  .mf-result-box.valid-setup .mf-result-text { color:#34c759; }
  .mf-result-box.invalid-setup .mf-result-text { color:#ff3b30; }
  .mf-result-sub { font-size:0.78rem; color:#645a78; }

  .mf-reset-btn { padding:10px 24px; background:transparent; border:1px solid rgba(138,60,255,0.35); border-radius:8px; color:#c4a0ff; font-family:'Orbitron',sans-serif; font-size:0.65rem; letter-spacing:2px; cursor:pointer; transition:all 0.2s; }
  .mf-reset-btn:hover { background:rgba(138,60,255,0.1); }
  </style>
</head>
<body>

<canvas id="divineCanvas"></canvas>

<div class="app-container">

  <!-- LOGIN -->
  <div id="login-screen">
    <div class="gate-box">
      <h2>⛧ T.N.S.V.T ⛧</h2>
      <p class="sub">NEURO-SPIRITUAL VALUE THEORY</p>
      <input type="text" id="gateKey" placeholder="TU CÓDIGO DE ACCESO" autofocus oninput="toggleAdminPassField()" onkeydown="if(event.key==='Enter'){event.preventDefault();maybeFocusPass();}" style="text-transform:uppercase;">
      <div id="gatePassWrap" style="position:relative; display:none; margin-top:8px;">
        <input type="password" id="gatePass" placeholder="CONTRASEÑA" style="padding-right:38px;" onkeydown="if(event.key==='Enter'){event.preventDefault();verifyGateKey();}">
        <button type="button" id="gatePassToggle" onclick="togglePassVisibility()" title="Mostrar/ocultar contraseña" style="position:absolute; right:6px; top:50%; transform:translateY(-50%); background:transparent; border:none; color:#645a78; cursor:pointer; font-size:1rem; padding:4px 8px; line-height:1;">👁</button>
      </div>
      <button class="login-btn" onclick="verifyGateKey()">ENTRAR AL GATEWAY</button>
      <p id="adminPassHint" style="display:none; font-size:0.75rem; color:var(--gold); margin-top:8px;">👑 Admin detectado — ingresá tu contraseña</p>
      <p id="loginError" style="display:none; font-size:0.82rem; color:#ff7066; margin-top:10px; padding:8px 12px; background:rgba(255,59,48,0.1); border:1px solid rgba(255,59,48,0.3); border-radius:8px;"></p>
    </div>
  </div>

  <!-- MAIN CONTENT (oculto hasta login) -->
  <div id="main-content" style="display:none; width:100%;">

    <!-- LOADING BAR GLOBAL (mientras se inicializan los paneles) -->
    <div id="appLoadingBar" style="position:fixed; top:0; left:0; right:0; height:3px; background:transparent; z-index:200000; pointer-events:none;">
      <div id="appLoadingBarFill" style="height:100%; width:0%; background:linear-gradient(90deg,var(--violet),var(--gold-bright)); box-shadow:0 0 8px var(--gold-bright); transition:width 0.3s ease;"></div>
    </div>
    <div id="appLoadingToast" style="position:fixed; top:12px; left:50%; transform:translateX(-50%); z-index:200000; background:rgba(13,8,24,0.95); border:1px solid rgba(212,175,55,0.4); border-radius:20px; padding:6px 14px; font-size:0.75rem; color:var(--gold-bright); font-family:'Orbitron',sans-serif; letter-spacing:0.5px; box-shadow:0 4px 16px rgba(0,0,0,0.4); backdrop-filter:blur(8px); display:none; align-items:center; gap:8px;">
      <span style="display:inline-block; width:10px; height:10px; border:2px solid var(--gold); border-top-color:transparent; border-radius:50%; animation:spin 0.8s linear infinite;"></span>
      <span id="appLoadingText">Cargando reino…</span>
    </div>
    <style>
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>

    <!-- OVERLAY DE CARGA (cubre el contenido hasta que initAllPanels termine) -->
    <div id="appLoadingOverlay" style="position:absolute; top:0; left:0; right:0; bottom:0; background:rgba(9,5,18,0.92); z-index:1500; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:40px; backdrop-filter:blur(4px);">
      <div style="width:60px; height:60px; border:4px solid rgba(212,175,55,0.2); border-top-color:var(--gold-bright); border-radius:50%; animation:spin 1s linear infinite; margin-bottom:20px;"></div>
      <div style="font-family:'Cinzel',serif; color:var(--gold-bright); font-size:1.3rem; margin-bottom:8px;">Cargando el Reino</div>
      <div id="appLoadingStatus" style="font-size:0.85rem; color:#a499b8; text-align:center; max-width:400px;">Inicializando paneles…</div>
      <div style="margin-top:20px; min-width:300px; max-width:400px; width:80%; height:6px; background:rgba(255,255,255,0.06); border-radius:3px; overflow:hidden;">
        <div id="appLoadingProgress" style="height:100%; width:0%; background:linear-gradient(90deg,var(--violet),var(--gold-bright)); transition:width 0.3s ease;"></div>
      </div>
      <div id="appLoadingCounter" style="font-size:0.7rem; color:#645a78; margin-top:10px; font-family:'Orbitron',sans-serif;">0/0</div>
    </div>

    <!-- HEADER -->
    <div class="app-header">
      <div class="logo-area"><h1>T.N.S.V.T</h1><p>Reino del Cristo Íntegro</p></div>
      <div class="user-badge">
        <!-- CAMPANA DE NOTIFICACIONES -->
        <div class="notif-bell-wrap" id="notifBellWrap">
          <div class="notif-bell-btn" id="notifBellBtn" onclick="toggleNotifPanel()">
            🔔
            <span class="notif-badge" id="notifBadge">0</span>
          </div>
          <div class="notif-panel" id="notifPanel">
            <div class="notif-panel-header">
              <span class="notif-panel-title">Notificaciones</span>
              <button class="notif-mark-all" onclick="markAllRead()">Marcar todo leído</button>
            </div>
            <div class="notif-list" id="notifList">
              <div class="notif-empty">🔔<br>Sin notificaciones aún.<br>Las señales y actividad del feed<br>aparecerán aquí.</div>
            </div>
          </div>
        </div>
        <div class="user-info"><div class="user-codename" id="profileCodename">Alma Electa</div><div class="user-status" id="profileRole">Conexión Divina</div></div>
        <button class="logout-btn" onclick="logout()">Desconectar</button>
      </div>
    </div>
    <!-- BANNER PERMISOS PUSH -->
    <div class="push-perm-bar" id="pushPermBar">
      <span>🔔 Activá notificaciones del navegador para recibir alertas de señales incluso con la app cerrada.</span>
      <div style="display:flex;gap:8px;align-items:center;">
        <button class="push-allow-btn" onclick="requestPushPermission()">Activar</button>
        <button class="push-dismiss-btn" onclick="dismissPushBar()">Ahora no</button>
      </div>
    </div>

    <!-- HUB CENTRAL -->
    <div id="hub-view" class="hub-view">
      <div class="diagram-container">
        <svg class="vector-lines" id="svgLines"></svg>
        <div id="node-god" class="top-identity">Dios / Identidad</div>
        <div id="cristoNode" class="hexagon-wrapper">
          <div class="hexagon-border"><div class="hexagon-content"><span class="cross">†</span><span class="label">EL CRISTO<br>ÍNTEGRO</span></div></div>
        </div>
        <div id="node-psi" class="rect-node pos-psi" onclick="handleNodeClick('psi')">PSICOLOGÍA BIOLÓGICA</div>
        <div id="node-tec" class="rect-node pos-tec" onclick="handleNodeClick('tec')">ANÁLISIS DE LIQUIDEZ</div>
        <div id="node-fun" class="rect-node pos-fun" onclick="handleNodeClick('fun')">FLUJO MACROECONÓMICO</div>
        <div id="node-fib" class="rect-node pos-fib" onclick="handleNodeClick('fib')">FIBONACCI SAGRADO</div>
        <div id="node-step" class="rect-node pos-step" onclick="handleNodeClick('step')">GATILLO 2 STEPS</div>
      </div>
      <div class="bottom-branding">
        <div class="main-logo-text">T.N.S.V.T</div>
        <div class="branding-mantra">Domina tu mente. Regula tu cuerpo. Ejecuta con fe.</div>
      </div>
      <div id="triggerCircle" class="bottom-trigger-circle" onclick="clickTriggerCircle()"><span>†</span></div>
    </div>

    <!-- PANEL DE MÓDULOS (estudio de los 5 nodos) -->
    <div id="module-panel" style="display:none; width:100%; max-width:900px; margin:20px auto; padding:20px; background:rgba(13,8,24,0.95); border:1px solid rgba(138,60,255,0.3); border-radius:20px;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h2 id="moduleTitle" style="font-family:'Cinzel'; color:var(--gold-bright);">Módulo</h2>
        <button class="back-btn" onclick="closeModule()">← Volver</button>
      </div>
      <div id="moduleContent"></div>
    </div>

    <!-- ==================== PANEL PRINCIPAL DEL CRISTO ÍNTEGRO ==================== -->
    <div id="trading-panel" style="display:none; width:100%;">
      <div class="inner-page" style="max-width:1150px; margin:0 auto; padding:20px;">
        <div class="section-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
          <div>
            <h2 style="font-family:'Cinzel',serif; font-size:1.8rem; color:var(--gold-bright);">🏛️ EL CRISTO ÍNTEGRO</h2>
            <p style="font-size:0.85rem; color:var(--violet); font-family:'Orbitron', sans-serif; margin-top:2px;">Edición Completa - Trading Neuro-Spiritual Value Theory (2026)</p>
          </div>
          <button class="back-btn" onclick="closeTradingPanel()">🔒 Cerrar Estación</button>
        </div>

        <div class="trading-layout">
          <div class="trading-sidebar">
            <button class="sidebar-btn active" onclick="switchTab('tab-posts')">📰 Manuscrito &amp; Comunidad</button>
            <button class="sidebar-btn" onclick="switchTab('tab-macro')">🌐 Macroeconomía Avanzada</button>
            <button class="sidebar-btn" onclick="switchTab('tab-2steps-adv')">⚡ Metodología 2 Steps <span class="lock-badge" id="badge-2step-lock" style="background:rgba(52,199,89,0.15); border-color:#34c759;">⚡ Activo</span></button>
            <button class="sidebar-btn" onclick="switchTab('tab-tasks')">✍️ Tareas Operativas <span id="task-counter" style="font-size:0.8rem; color:var(--gold-bright);"></span></button>
            <button class="sidebar-btn" onclick="switchTab('tab-calendar')">📅 Calendario Económico</button>
            <button class="sidebar-btn" onclick="switchTab('tab-journal')">📊 Trading Journal</button>
            <button class="sidebar-btn" onclick="switchTab('tab-academia')">🎓 Academia</button>
            <button class="sidebar-btn" onclick="switchTab('tab-chat')">💬 Chat de Ejecutores</button>
            <button class="sidebar-btn" id="adminSidebarBtn" onclick="switchTab('tab-admin')" style="display:none;">⚙️ Admin</button>
          </div>

          <div class="trading-main">

            <!-- TAB 0: MANUSCRITO & COMUNIDAD (FEED) -->
            <div id="tab-posts" class="tab-content active">
              <div class="feed-cats" id="feedCats">
                <div style="display:flex;justify-content:space-between;align-items:center;width:100%;margin-bottom:8px;">
                  <div style="display:flex;gap:6px;flex-wrap:wrap;">
                    <button class="feed-cat active" onclick="filterFeed('all',this)">Todos</button>
                    <button class="feed-cat" onclick="filterFeed('general',this)">General</button>
                    <button class="feed-cat" onclick="filterFeed('señales',this)">Señales</button>
                    <button class="feed-cat" onclick="filterFeed('resultados',this)">Resultados</button>
                    <button class="feed-cat" onclick="filterFeed('proyecciones',this)">Proyecciones</button>
                    <button class="feed-cat" onclick="filterFeed('pregunta',this)">Preguntas</button>
                  </div>
                  <div style="display:flex;align-items:center;gap:5px;font-size:0.62rem;color:#645a78;font-family:'Orbitron',sans-serif;letter-spacing:1px;flex-shrink:0;">
                    <span id="feed-live-dot" style="width:6px;height:6px;border-radius:50%;background:#34c759;box-shadow:0 0 6px #34c759;animation:pulseGlow 1.5s infinite alternate;display:inline-block;"></span>
                    EN VIVO
                    <button onclick="renderFeed()" style="background:transparent;border:1px solid rgba(212,175,55,0.15);border-radius:4px;color:#645a78;padding:2px 6px;cursor:pointer;font-size:0.55rem;">↻</button>
                  </div>
                </div>
              </div>
              <div class="create-post-box">
                <textarea id="newPostText" placeholder="Compartí un análisis, pregunta o señal con la comunidad..."></textarea>
                <div class="create-post-row">
                  <div class="create-cat-sel">
                    <button class="create-cat-opt sel" onclick="selPostCat('general',this)">General</button>
                    <button class="create-cat-opt" onclick="selPostCat('señales',this)">Señal</button>
                    <button class="create-cat-opt" onclick="selPostCat('resultados',this)">Resultado</button>
                    <button class="create-cat-opt" onclick="selPostCat('proyecciones',this)">Proyección</button>
                    <button class="create-cat-opt" onclick="selPostCat('pregunta',this)">Pregunta</button>
                  </div>
                  <div style="display:flex;gap:6px;">
                    <button style="padding:6px 12px;background:transparent;border:1px solid rgba(212,175,55,0.2);border-radius:6px;color:#645a78;cursor:pointer;font-size:0.75rem;" onclick="toggleSignalForm()">📊 + Señal</button>
