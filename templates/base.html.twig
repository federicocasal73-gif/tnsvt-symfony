      <div style="display:flex; align-items:center; gap:10px; margin:18px 0 10px; color:#645a78; font-size:0.78rem;">
        <div style="flex:1; height:1px; background:rgba(212,175,55,0.15);"></div>
        <span style="font-family:'Orbitron',sans-serif; letter-spacing:2px;">➕ AGREGAR TRACK</span>
        <div style="flex:1; height:1px; background:rgba(212,175,55,0.15);"></div>
      </div>

      <label id="adminMusicDropZone" style="display:block; border:2px dashed rgba(212,175,55,0.35); border-radius:12px; padding:24px; text-align:center; cursor:pointer; transition:all 0.2s; background:rgba(0,0,0,0.25); margin-bottom:14px;" onmouseover="this.style.borderColor='var(--gold-bright)';this.style.background='rgba(212,175,55,0.06)'" onmouseout="this.style.borderColor='rgba(212,175,55,0.35)';this.style.background='rgba(0,0,0,0.25)'">
        <div style="font-size:1.8rem; margin-bottom:6px;">⬆️</div>
        <div style="font-family:'Cinzel',serif; color:var(--gold-bright); margin-bottom:4px;">Subí un archivo de audio</div>
        <div style="font-size:0.75rem; color:#a499b8;">Click o arrastrá un .mp3 / .wav / .ogg / .m4a — máx 200 MB</div>
        <input type="file" id="adminMusicFile" accept="audio/mpeg,audio/mp3,audio/wav,audio/ogg,audio/mp4,audio/x-m4a,audio/aac" style="display:none;" onchange="adminMusicUpload(this)">
      </label>

      <div style="display:flex; align-items:center; gap:10px; margin:6px 0 8px; color:#645a78; font-size:0.7rem;">
        <div style="flex:1; height:1px; background:rgba(212,175,55,0.1);"></div>
        <span style="font-family:'Orbitron',sans-serif; letter-spacing:2px;">🌐 O PEGÁ UNA URL</span>
        <div style="flex:1; height:1px; background:rgba(212,175,55,0.1);"></div>
      </div>
      <p style="font-size:0.72rem; color:#a499b8; margin-bottom:8px;">Google Drive, Dropbox, link directo, etc. Para archivos pesados en la nube.</p>
      <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:14px;">
        <input type="text" id="adminMusicExternalUrl" placeholder="https://ejemplo.com/mi-musica.mp3" style="flex:1; min-width:220px; padding:10px 14px; background:rgba(0,0,0,0.4); border:1px solid rgba(212,175,55,0.25); border-radius:8px; color:#fff; font-family:inherit; font-size:0.85rem; outline:none;">
        <input type="text" id="adminMusicExternalLabel" placeholder="Nombre (opcional)" style="flex:0 1 200px; padding:10px 14px; background:rgba(0,0,0,0.4); border:1px solid rgba(212,175,55,0.25); border-radius:8px; color:#fff; font-family:inherit; font-size:0.85rem; outline:none;">
        <button class="post-btn" onclick="adminMusicSetExternal()" style="white-space:nowrap;">🌐 Agregar</button>
      </div>

      <div id="adminMusicProgress" style="display:none; margin-top:12px; padding:12px; background:rgba(0,0,0,0.4); border:1px solid rgba(212,175,55,0.2); border-radius:8px;">
        <div style="font-size:0.8rem; color:#a499b8; margin-bottom:6px;">Subiendo <span id="adminMusicFileName"></span>...</div>
        <div style="height:6px; background:rgba(255,255,255,0.08); border-radius:3px; overflow:hidden;">
          <div id="adminMusicBar" style="height:100%; width:0%; background:linear-gradient(90deg,var(--violet),var(--gold-bright)); transition:width 0.2s;"></div>
        </div>
      </div>

      <p id="adminMusicFeedback" style="font-size:0.82rem; margin-top:12px; min-height:1.2em;"></p>
    </div>
  </div>
</div>
  </div>
</div>

<!-- ==================== FIN DEL HTML DEL PANEL ==================== -->

<!-- ==================== PLAYER DE MÚSICA DE FONDO ==================== -->
<audio id="bgMusicAudio" preload="auto" style="display:none;"></audio>
<div id="musicPlayer" style="position:fixed; bottom:20px; right:20px; z-index:100000; background:rgba(13,8,24,0.97); border:1px solid rgba(212,175,55,0.3); border-radius:14px; padding:8px 10px; display:flex; flex-direction:column; gap:6px; box-shadow:0 8px 32px rgba(0,0,0,0.6); backdrop-filter:blur(8px); min-width:300px; max-width:360px; font-family:inherit; transition:all 0.3s;">
  <div style="display:flex; align-items:center; gap:8px;">
    <button id="musicPrevBtn" onclick="musicPrev()" title="Anterior" style="width:28px; height:28px; border-radius:50%; background:rgba(138,60,255,0.15); border:1px solid rgba(138,60,255,0.3); color:#c4a0ff; cursor:pointer; font-size:0.7rem; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:all 0.2s;" onmouseover="this.style.background='rgba(138,60,255,0.3)'" onmouseout="this.style.background='rgba(138,60,255,0.15)'">⏮</button>
    <button id="musicToggleBtn" onclick="musicToggle()" title="Reproducir / Pausar" style="width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--violet),var(--gold)); border:none; color:#fff; cursor:pointer; font-size:1.05rem; display:flex; align-items:center; justify-content:center; flex-shrink:0; box-shadow:0 0 12px rgba(212,175,55,0.4);">▶</button>
    <button id="musicNextBtn" onclick="musicNext()" title="Siguiente" style="width:28px; height:28px; border-radius:50%; background:rgba(138,60,255,0.15); border:1px solid rgba(138,60,255,0.3); color:#c4a0ff; cursor:pointer; font-size:0.7rem; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:all 0.2s;" onmouseover="this.style.background='rgba(138,60,255,0.3)'" onmouseout="this.style.background='rgba(138,60,255,0.15)'">⏭</button>
    <canvas id="musicVisualizer" width="120" height="32" style="flex:1; min-width:0; height:32px; border-radius:6px; background:rgba(0,0,0,0.3);"></canvas>
    <button onclick="musicToggleQueue()" title="Ver playlist" style="background:transparent; border:none; color:#645a78; cursor:pointer; font-size:0.85rem; padding:0 2px; line-height:1; position:relative;">☰<span id="musicQueueBadge" style="display:none; position:absolute; top:-4px; right:-6px; background:var(--gold-bright); color:#000; font-size:0.5rem; font-weight:700; padding:1px 4px; border-radius:8px; min-width:12px; text-align:center;"></span></button>
    <button onclick="musicMinimize()" title="Minimizar" style="background:transparent; border:none; color:#645a78; cursor:pointer; font-size:1rem; padding:0 2px; line-height:1;">─</button>
  </div>
  <div style="display:flex; align-items:center; gap:6px; padding:0 2px;">
    <div id="musicTitle" style="flex:1; min-width:0; font-size:0.7rem; color:var(--gold-bright); font-family:'Orbitron',sans-serif; letter-spacing:0.3px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Sin música</div>
    <div id="musicTrackCount" style="font-size:0.6rem; color:#645a78; font-family:'Orbitron',sans-serif; flex-shrink:0;">0/0</div>
  </div>
  <div style="display:flex; align-items:center; gap:6px;">
    <button id="musicLoopBtn" onclick="musicCycleLoop()" title="Loop" style="background:transparent; border:none; color:#645a78; cursor:pointer; font-size:0.7rem; padding:0 2px;">🔁</button>
    <span style="font-size:0.6rem; color:#645a78;">🔈</span>
    <input id="musicVolume" type="range" min="0" max="100" value="35" oninput="musicSetVolume(this.value)" style="flex:1; height:4px; cursor:pointer; accent-color:var(--gold-bright);">
    <span style="font-size:0.6rem; color:#645a78;">🔊</span>
  </div>
  <div id="musicProgressWrap" style="height:3px; background:rgba(255,255,255,0.08); border-radius:2px; overflow:hidden; cursor:pointer; margin:0 2px;" onclick="musicSeek(event)">
    <div id="musicProgressBar" style="height:100%; width:0%; background:linear-gradient(90deg,var(--violet),var(--gold-bright)); transition:width 0.25s linear;"></div>
  </div>
</div>
<div id="musicQueuePanel" style="display:none; position:fixed; bottom:140px; right:20px; z-index:100001; background:rgba(13,8,24,0.98); border:1px solid rgba(212,175,55,0.3); border-radius:14px; padding:10px; min-width:320px; max-width:360px; max-height:380px; overflow-y:auto; box-shadow:0 8px 32px rgba(0,0,0,0.6); backdrop-filter:blur(8px);">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
    <div style="font-family:'Orbitron',sans-serif; font-size:0.7rem; color:var(--gold-bright); letter-spacing:1px;">🎵 PLAYLIST</div>
    <button onclick="musicToggleQueue()" style="background:transparent; border:none; color:#645a78; cursor:pointer; font-size:1rem; padding:0 4px; line-height:1;">✕</button>
  </div>
  <div id="musicQueueList"></div>
  <div id="musicQueueEmpty" style="text-align:center; color:#645a78; padding:20px; font-size:0.82rem;">La playlist está vacía.<br><span style="font-size:0.7rem;">Pedile al admin que suba música.</span></div>
</div>
<div id="musicPlayerMini" style="display:none; position:fixed; bottom:20px; right:20px; z-index:100000; background:rgba(13,8,24,0.95); border:1px solid rgba(212,175,55,0.3); border-radius:50%; width:46px; height:46px; cursor:pointer; box-shadow:0 4px 16px rgba(0,0,0,0.5);" onclick="musicExpand()" title="Mostrar reproductor">
  <canvas id="musicMiniVisualizer" width="46" height="46" style="position:absolute; inset:0; border-radius:50%; pointer-events:none;"></canvas>
  <div style="display:flex; align-items:center; justify-content:center; height:100%; font-size:1.1rem; position:relative; z-index:1;">🎵</div>
</div>
          </div> <!-- cierra trading-main -->
        </div> <!-- cierra trading-layout -->
      </div> <!-- cierra inner-page -->
    </div> <!-- cierra trading-panel -->

  </div> <!-- cierra main-content -->

    <div id="toast">Notificación Operativa</div>

    <!-- ==================== MODAL: NUEVO MENSAJE PRIVADO ==================== -->
    <div id="newDmOverlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:10001; align-items:center; justify-content:center; padding:20px;">
      <div style="background:rgba(13,8,24,0.99); border:1px solid rgba(212,175,55,0.3); border-radius:16px; width:100%; max-width:480px; max-height:80vh; display:flex; flex-direction:column;">
        <div style="display:flex; justify-content:space-between; align-items:center; padding:16px 20px; border-bottom:1px solid rgba(212,175,55,0.15);">
          <span style="font-family:'Cinzel',serif; font-size:1.1rem; color:var(--gold-bright);">✉️ Nuevo mensaje</span>
          <button onclick="closeNewDmModal()" style="background:none; border:none; color:#645a78; font-size:1.4rem; cursor:pointer;">✕</button>
        </div>
        <div style="padding:12px 20px;">
          <input type="text" id="newDmSearch" placeholder="Buscar usuario..." oninput="filterNewDmList()" style="width:100%; padding:10px 14px; background:rgba(0,0,0,0.5); border:1px solid rgba(212,175,55,0.2); border-radius:8px; color:#fff; font-family:inherit; font-size:0.9rem; outline:none;">
        </div>
        <div id="newDmUserList" style="flex:1; overflow-y:auto; padding:0 12px 16px;">
          <div style="padding:20px; text-align:center; color:#645a78;">Cargando usuarios...</div>
        </div>
      </div>
    </div>

      </div>
    </div>
</body>
</html>