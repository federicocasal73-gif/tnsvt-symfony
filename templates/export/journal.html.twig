<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Journal {{ user.name }} - TNSVT</title>
<style>
  @page { margin: 20mm 15mm; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', Arial, sans-serif; background: #fff; color: #222; padding: 30px; }
  h1 { font-size: 1.6rem; margin-bottom: 4px; }
  .sub { color: #666; font-size: 0.85rem; margin-bottom: 20px; }
  table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  th { background: #f5f5f5; text-align: left; padding: 8px 10px; border-bottom: 2px solid #ddd; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px; color: #555; }
  td { padding: 7px 10px; border-bottom: 1px solid #eee; }
  .win { color: #16a34a; font-weight: 600; }
  .loss { color: #dc2626; font-weight: 600; }
  .be { color: #d97706; font-weight: 600; }
  .buy { color: #16a34a; }
  .sell { color: #dc2626; }
  .pnl-pos { color: #16a34a; }
  .pnl-neg { color: #dc2626; }
  .stats { display: flex; gap: 20px; margin-bottom: 24px; flex-wrap: wrap; }
  .stat { background: #f9f9f9; border-radius: 8px; padding: 12px 18px; min-width: 120px; }
  .stat-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.5px; color: #888; }
  .stat-val { font-size: 1.2rem; font-weight: 700; margin-top: 2px; }
  .footer { margin-top: 30px; font-size: 0.7rem; color: #999; text-align: center; border-top: 1px solid #eee; padding-top: 15px; }
  @media print { body { padding: 0; } .no-print { display: none; } }
</style>
</head>
<body>
  <h1>📊 Trading Journal — {{ user.name }}</h1>
  <div class="sub">Generado el {{ generated|date('d/m/Y H:i') }} · {{ trades|length }} trades</div>

  <div class="stats">
    {% set wins = trades|filter(t => t.result == 'WIN')|length %}
    {% set losses = trades|filter(t => t.result == 'LOSS')|length %}
    {% set pnl = trades|reduce((c, t) => c + t.pnl, 0) %}
    {% set winRate = trades|length > 0 ? (wins / trades|length * 100)|round(1) : 0 %}
    <div class="stat"><div class="stat-label">Total Trades</div><div class="stat-val">{{ trades|length }}</div></div>
    <div class="stat"><div class="stat-label">Win Rate</div><div class="stat-val">{{ winRate }}%</div></div>
    <div class="stat"><div class="stat-label">W / L</div><div class="stat-val">{{ wins }} / {{ losses }}</div></div>
    <div class="stat"><div class="stat-label">PNL Neto</div><div class="stat-val" style="color:{{ pnl >= 0 ? '#16a34a' : '#dc2626' }}">{{ pnl >= 0 ? '+' : '' }}{{ pnl|number_format(2) }}</div></div>
  </div>

  <table>
    <thead>
      <tr>
        <th>Fecha</th><th>Activo</th><th>Dir</th><th>Entry</th><th>SL</th><th>TP</th><th>Resultado</th><th>PNL</th><th>R:B</th><th>Notas</th>
      </tr>
    </thead>
    <tbody>
    {% for t in trades %}
      <tr>
        <td>{{ t.date ? t.date|date('d/m/Y H:i') : '-' }}</td>
        <td><strong>{{ t.asset }}</strong></td>
        <td class="{{ t.direction == 'BUY' ? 'buy' : 'sell' }}">{{ t.direction }}</td>
        <td>{{ t.entry ?? '-' }}</td>
        <td>{{ t.sl ?? '-' }}</td>
        <td>{{ t.tp ?? '-' }}</td>
        <td class="{{ t.result == 'WIN' ? 'win' : (t.result == 'LOSS' ? 'loss' : 'be') }}">{{ t.result }}</td>
        <td class="{{ t.pnl >= 0 ? 'pnl-pos' : 'pnl-neg' }}">{{ t.pnl >= 0 ? '+' : '' }}{{ t.pnl|number_format(2) }}</td>
        <td>{{ t.ratio ?? '-' }}</td>
        <td>{{ t.notes ?? '' }}</td>
      </tr>
    {% else %}
      <tr><td colspan="10" style="text-align:center;padding:30px;color:#999;">No hay trades registrados.</td></tr>
    {% endfor %}
    </tbody>
  </table>

  <div class="footer">TNSVT — Trading Journal · {{ generated|date('Y') }}</div>
  <div class="no-print" style="margin-top:12px;text-align:center;"><button onclick="window.print()" style="padding:8px 24px;cursor:pointer;">🖨 Imprimir / Guardar PDF</button></div>
</body>
</html>
