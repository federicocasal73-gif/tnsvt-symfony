# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# Default dev: file (escribe a var/log/emails/ - podes abrirlos en el browser)
# Para activar SMTP real, descomentar y configurar:
# Gmail: MAILER_DSN=smtp://user:pass@smtp.gmail.com:587
# Mailtrap: MAILER_DSN=smtp://user:pass@smtp.mailtrap.io:2525
MAILER_DSN=null://null
###< symfony/mailer ###

###> tnsvt email ###
APP_SERVER_URL=http://100.108.182.28:8000
APP_EMAIL_FROM=no-reply@tnsvt.app
APP_EMAIL_FROM_NAME=T.N.S.V.T
###< tnsvt email ###

###> tnsvt ###
# Contrasena del panel admin de Academia (gestion de cursos)
# En produccion, override en .env.local o variable de entorno del servidor
ACADEMIA_ADMIN_PASS=TNSVT-Academia-2026
###< tnsvt ###

###> nelmio/cors-bundle ###
# Dominios permitidos para CORS. En dev, aceptar todo.
# En produccion, cambiar a tu dominio: CORS_ALLOW_ORIGIN=^https?://(localhost|tudominio\.com)(:[0-9]+)?$
# Acepta: localhost, 127.0.0.1, IP del emulador (10.0.2.2), IP de LAN (192.168.x.x)
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1|10\.0\.2\.2|192\.168\.\d+\.\d+)(:[0-9]+)?$
###< nelmio/cors-bundle ###

###> nelmio/cors-bundle ###
# Acepta: localhost, 127.0.0.1, IP del emulador (10.0.2.2), IP de LAN (192.168.x.x),
# IP de Tailscale (100.x.y.z). El primer bloque es documentacion, este es el activo.
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1|10\.0\.2\.2|192\.168\.\d+\.\d+|100\.\d+\.\d+\.\d+)(:[0-9]+)?$
###< nelmio/cors-bundle ###

###> tnsvt/app-version ###
# Version actual de la app TNSVT (mostrada en pantalla de update).
# Para publicar una nueva version: cambiar APP_VERSION, APP_VERSION_CODE
# (y opcionalmente APP_RELEASE_NOTES), rebuildar el APK, hostearlo en
# APP_DOWNLOAD_URL, y reiniciar el server. La app detectara la nueva version
# al abrirla y mostrara el modal de update.
APP_VERSION=1.3.1
APP_VERSION_CODE=8
APP_DOWNLOAD_URL=http://100.108.182.28:8000/api/app/download-web
APP_RELEASE_NOTES="- Chart en vivo corregido (symbols/intervals)
- Bugs de sesión y errores silenciosos arreglados
- Tailscale habilitado para acceso remoto"
###< tnsvt/app-version ###

###> firebase/push-notifications ###
# Path al service account JSON de Firebase. Bajar desde:
# Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# Guardar el archivo en var/firebase/service-account.json y descomentar la linea
# Si esta vacio, las notificaciones funcionan in-app pero NO llegan como push.
FIREBASE_CREDENTIALS_PATH=var/firebase/service-account.json

# ==== FIREBASE WEB PUSH (frontend) ====
# Datos PUBLICOS de la Web App de Firebase (se exponen al cliente).
# Obtener desde: Firebase Console -> Project Settings -> Your apps -> Web app -> Config
# Reemplazar los placeholders abajo con los valores reales.
# Si no se configuran, /api/firebase/config devuelve 503 y el SW no se inicializa
# (las notificaciones in-app siguen funcionando).
FIREBASE_WEB_API_KEY=YOUR_API_KEY
FIREBASE_AUTH_DOMAIN=tnsvt-app.firebaseapp.com
FIREBASE_PROJECT_ID=tnsvt-app
FIREBASE_STORAGE_BUCKET=tnsvt-app.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID
# VAPID key para Web Push (opcional, recomendado):
# Firebase Console -> Project Settings -> Cloud Messaging -> Web Push certificates -> Generate key pair
FIREBASE_WEB_PUSH_VAPID_KEY=

###< firebase/push-notifications ###

###< mercadopago ###
# Access Token de MercadoPago Argentina (produccion). Generar desde:
# https://www.mercadopago.com.ar/developers/panel -> Credenciales -> Access Token
# Dejalo vacio si no lo tenes (los endpoints devuelven 501 Not Implemented).
MP_ACCESS_TOKEN=
# URL base de la API de MP (produccion o sandbox)
MP_API_URL=https://api.mercadopago.com
# URLs de redireccion post-pago
MP_SUCCESS_URL=http://100.108.182.28:8000/?pg=ok
MP_FAILURE_URL=http://100.108.182.28:8000/?pg=error
MP_PENDING_URL=http://100.108.182.28:8000/?pg=pending
# External Reference prefix para identificar pagos TNSVT
MP_EXT_REF_PREFIX=tnsvt_mp_
###< mercadopago ###

###< binance_pay ###
# API Key y Secret Key de Binance Pay Merchant.
# Obtener en: https://merchant.binance.com -> API Management
# Dejalo vacio si no lo tenes (los endpoints devuelven 501).
BINANCE_PAY_API_KEY=
BINANCE_PAY_SECRET_KEY=
BINANCE_PAY_API_URL=https://bpay.binanceapi.com
# Nonce expiry en segundos (default 60)
BINANCE_PAY_NONCE_EXPIRY=60
###< binance_pay ###

###< fcm ###
# Ruta al JSON de service account (Firebase Admin SDK) para FCM v1 API.
# Descargar de: Firebase Console -> Project Settings -> Service accounts -> Generate new private key
FCM_SERVICE_ACCOUNT=android/app/juego-app-store-trading-firebase-adminsdk-fbsvc-81993dce61.json
# Legacy FCM Server Key (fallback si no hay service account)
# FCM_SERVER_KEY=AIzaSyB9Jg1inIXJerASbJVpHQJrEmlpF1UBoHs
###< fcm ###
